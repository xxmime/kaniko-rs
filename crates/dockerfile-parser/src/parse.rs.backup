/// Join continuation lines (lines ending with `\`).
fn join_continuation_lines(content: &str) -> String {
    let mut result = String::with_capacity(content.len());
    let mut pending_continuation = false;

    for line in content.lines() {
        let trimmed_end = line.trim_end_matches(' ');
        if trimmed_end.ends_with('\\') {
            // Remove the trailing backslash and join with next line
            let line_without_backslash = &trimmed_end[..trimmed_end.len() - 1];
            if pending_continuation {
                result.push_str(line_without_backslash.trim());
            } else {
                result.push_str(line_without_backslash);
                pending_continuation = true;
            }
        } else {
            if pending_continuation {
                result.push_str(line.trim());
                pending_continuation = false;
            } else {
                result.push_str(line);
            }
            result.push('\n');
        }
