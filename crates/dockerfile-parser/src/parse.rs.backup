    /// Look up a variable: prefer build_args > env > args.
    pub fn get(&self, name: &str) -> Option<String> {
        if let Some(v) = self.build_args.get(name) {
            return Some(v.clone());
        }
        if let Some(v) = self.env.get(name) {
            return Some(v.clone());
        }
        if let Some(v) = self.args.get(name) {
            return Some(v.clone());
        }
        None
