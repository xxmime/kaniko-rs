/// Parse ONBUILD instruction — parses the nested instruction.
fn parse_onbuild_instruction(rest: &str) -> Result<Instruction> {
    let (directive, inner_rest) = split_directive(rest);
    match directive.to_uppercase().as_str() {
        "RUN" => Ok(Instruction::Run(RunInstruction {
            command: inner_rest.trim().to_string(),
            is_shell_form: true,
        })),
        "CMD" => Ok(Instruction::Cmd(CmdInstruction {
            command: parse_string_list(inner_rest),
            is_shell_form: false,
        })),
        "COPY" => {
            let (sources, dest, from) = parse_copy(inner_rest);
            Ok(Instruction::Copy(CopyInstruction {
                sources, destination: dest, from,
                chmod: None, chown: None, link: false,
            }))
        }
        "ADD" => {
            let (sources, dest) = parse_add(inner_rest);
            Ok(Instruction::Add(AddInstruction {
                sources, destination: dest,
                chmod: None, chown: None, link: false,
            }))
        }
        "ENV" => {
            let (key, value) = parse_env(inner_rest);
            Ok(Instruction::Env(EnvInstruction { key, value }))
        }
        "LABEL" => {
            let labels = parse_key_value_pairs(inner_rest);
            Ok(Instruction::Label(LabelInstruction { labels }))
        }
        "EXPOSE" => {
            let ports: Vec<String> = inner_rest.split_whitespace().map(String::from).collect();
            Ok(Instruction::Expose(ExposeInstruction { ports }))
        }
        "USER" => Ok(Instruction::User(UserInstruction {
            user: inner_rest.trim().to_string(),
        })),
        "WORKDIR" => Ok(Instruction::Workdir(WorkdirInstruction {
            path: inner_rest.trim().to_string(),
        })),
        "VOLUME" => {
            let paths = parse_string_list(inner_rest);
            Ok(Instruction::Volume(VolumeInstruction { paths }))
        }
        "ENTRYPOINT" => Ok(Instruction::Entrypoint(EntrypointInstruction {
            command: parse_string_list(inner_rest),
            is_shell_form: false,
        })),
        _ => Ok(Instruction::Run(RunInstruction {
            command: rest.to_string(),
            is_shell_form: true,
        })),
    }
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho \"Line 2\"");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run_quoted_delimiter() {
        let dockerfile = r#"
