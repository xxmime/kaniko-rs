fn parse_kv_pair(s: &str) -> Option<(String, String)> {
    if let Some(eq_pos) = s.find('=') {
        let key = s[..eq_pos].to_string();
        let value = s[eq_pos + 1..].to_string();
        Some((key, value))
    } else {
        None
    }
    #[test]
