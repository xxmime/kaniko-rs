/// Extract the heredoc delimiter from a line like "<<EOF" or "<<'EOF'".
fn extract_heredoc_delimiter(line: &str) -> String {
    let trimmed = line.trim();
    let start_pos = trimmed.find("<<").unwrap() + 2;
    let delimiter_part = &trimmed[start_pos..];
    
    // Handle quoted delimiters like <<'EOF' or <<"EOF"
    let delimiter = delimiter_part.trim();
    if delimiter.starts_with('"') || delimiter.starts_with('\'') {
        let quote_char = delimiter.chars().next().unwrap();
        delimiter[1..].split(quote_char).next().unwrap_or("").to_string()
    } else {
        delimiter.split_whitespace().next().unwrap_or("").to_string()
    }
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho \"Line 2\"");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
