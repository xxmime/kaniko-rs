fn add_instruction(
    stage: &mut Option<Stage>,
    instruction: Instruction,
    line: usize,
) -> Result<()> {
    if let Some(stage) = stage.as_mut() {
        stage.instructions.push(instruction);
    } else {
        return Err(ParseError::Syntax {
            line,
            message: "instruction before FROM".to_string(),
        });
    }
    Ok(())
