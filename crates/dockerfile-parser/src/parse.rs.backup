            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }
}

/// Check if a line starts a HEREDOC operator (<< or <<-).
fn is_heredoc_start(line: &str) -> bool {
    line.trim().starts_with("<<") && !line.trim().starts_with("<<<")
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
