    #[test]
    fn test_parse_dockerfile_with_arg_substitution() {
        let dockerfile = r#"
ARG BASE_IMAGE=ubuntu:20.04
FROM $BASE_IMAGE
ARG VERSION=1.0
ENV APP_VERSION=$VERSION
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].image, "ubuntu:20.04");
        // instructions: [0]=ARG(BASE_IMAGE), [1]=ARG(VERSION), [2]=ENV(APP_VERSION=1.0)
        assert_eq!(stages[0].instructions.len(), 3);
        // Check that ENV was substituted
        match &stages[0].instructions[2] {
            Instruction::Env(env) => assert_eq!(env.value, "1.0"),
            other => panic!("Expected ENV instruction, got {:?}", other),
        }
        #[test]
