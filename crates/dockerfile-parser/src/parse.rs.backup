/// Parse HEALTHCHECK instruction.
/// Format: HEALTHCHECK [OPTIONS] CMD command
///         HEALTHCHECK NONE
fn parse_healthcheck(rest: &str) -> Result<Instruction> {
    let rest = rest.trim();

    if rest.eq_ignore_ascii_case("NONE") {
        return Ok(Instruction::Healthcheck(HealthcheckInstruction {
            cmd: None,
            interval: None,
            timeout: None,
            start_period: None,
            retries: None,
            is_none: true,
        }));
        #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho \"Line 2\"");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run_quoted_delimiter() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<'SCRIPT'
echo "Hello World"
echo 'Line 2'
SCRIPT
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho 'Line 2'");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
