/// Parse COPY instruction.
fn parse_copy(rest: &str) -> (Vec<String>, String, Option<String>) {
    let mut from = None;
    let mut parts: Vec<String> = rest.split_whitespace().map(String::from).collect();

    // Handle --from=xxx
    let mut i = 0;
    while i < parts.len() {
        if parts[i].starts_with("--from=") {
            from = Some(parts[i][7..].to_string());
            parts.remove(i);
        } else {
            i += 1;
        }
