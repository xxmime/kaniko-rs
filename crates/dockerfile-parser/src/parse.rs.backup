/// Parse ARG instruction.
fn parse_arg(rest: &str) -> (String, Option<String>) {
    let rest = rest.trim();
    if let Some(eq_pos) = rest.find('=') {
        let name = rest[..eq_pos].to_string();
        let value = rest[eq_pos + 1..].trim_matches('"').to_string();
        (name, Some(value))
    } else {
        (rest.to_string(), None)
    }
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
