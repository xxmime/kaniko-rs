/// - `//! Dockerfile parser implementation.
//!
//! Parses a Dockerfile string into a list of [`Instruction`] values.
//! Supports:
//! - Multi-line continuation (`\` at end of line)
//! - ARG/ENV variable substitution (`$VAR`, `${VAR}`)
//! - All Dockerfile instructions including ONBUILD, STOPSIGNAL, HEALTHCHECK, SHELL

use crate::instruction::*;
use std::collections::HashMap;
use thiserror::Error;

/// Errors that can occur during parsing.
#[derive(Debug, Error)]
pub enum ParseError {
    #[error("IO error: {0}")]
    Io(#[from] std::io::Error),
    #[error("parse error at line {line}: {message}")]
    Syntax { line: usize, message: String },
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho \"Line 2\"");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run_quoted_delimiter() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<'SCRIPT'
echo "Hello World"
echo 'Line 2'
SCRIPT
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho 'Line 2'");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho \"Line 2\"");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }

    #[test]
    fn test_heredoc_run_quoted_delimiter() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<'SCRIPT'
echo "Hello World"
echo 'Line 2'
SCRIPT
"#;
        let stages = parse_dockerfile(dockerfile).unwrap();
        assert_eq!(stages[0].instructions.len(), 1);
        match &stages[0].instructions[0] {
            Instruction::Run(run) => {
                assert_eq!(run.command, "echo \"Hello World\"\necho 'Line 2'");
                assert!(run.is_shell_form);
            }
            other => panic!("Expected RUN instruction, got {:?}", other),
        }
    }
}

/// Result type for parsing.
pub type Result<T> = std::result::Result<T, ParseError>;

/// A parsed Dockerfile stage.
#[derive(Debug, Clone)]
pub struct Stage {
    /// Stage index (0-based).
    pub index: usize,
    /// Base image name.
    pub image: String,
    /// Optional alias (FROM ... AS alias).
    pub alias: Option<String>,
    /// Instructions in this stage.
    pub instructions: Vec<Instruction>,
    #[test]
    fn test_heredoc_run() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<EOF
echo "Hello World"
echo "Line 2"
EOF
"#;
