    }

    #[test]
    fn test_heredoc_run_quoted_delimiter() {
        let dockerfile = r#"
FROM ubuntu:20.04
RUN <<'SCRIPT'
echo "Hello World"
echo 'Line 2'
SCRIPT
"#;
