/// Parse ADD instruction.
fn parse_add(rest: &str) -> (Vec<String>, String) {
    let mut parts: Vec<String> = rest.split_whitespace().map(String::from).collect();
    if parts.len() >= 2 {
        let dest = parts.pop().unwrap();
        (parts, dest)
    } else {
        (vec![], String::new())
    }
